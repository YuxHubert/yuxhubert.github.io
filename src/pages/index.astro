---
import BaseLayout from '../layouts/BaseLayout.astro';
import { formatPostDate, getPublishedPosts } from '../lib/posts';

const recentPosts = (await getPublishedPosts()).slice(0, 3);
---

<BaseLayout
  title="Yuxhubert"
  description="Yuxhubert 的个人博客，记录学习、工具和长期思考。"
>
  <section class="intro-section" aria-labelledby="intro-title">
    <div class="intro-copy">
      <p class="eyebrow">个人博客</p>
      <h1 id="intro-title">Yuxhubert</h1>
      <p class="lead">
        这里用于整理学习笔记、工具经验和一些值得长期保存的想法。
      </p>
      <div class="intro-actions">
        <a class="text-link" href="/posts/">查看全部文章</a>
      </div>
    </div>
    <div class="intro-visual" aria-hidden="true">
      <img src="/favicon.svg" alt="" width="96" height="96" />
      <span>Markdown</span>
    </div>
  </section>

  <section class="content-section" aria-labelledby="recent-posts-title">
    <div class="section-heading">
      <p class="eyebrow">Recent</p>
      <h2 id="recent-posts-title">最近文章</h2>
    </div>

    <div class="post-grid">
      {
        recentPosts.map((post) => (
          <article class="post-card">
            <div class="post-meta">
              <time datetime={post.data.pubDate.toISOString()}>
                {formatPostDate(post.data.pubDate)}
              </time>
            </div>
            <h3>
              <a href={`/posts/${post.id}/`}>{post.data.title}</a>
            </h3>
            <p>{post.data.description}</p>
            <div class="tag-list" aria-label="文章标签">
              {post.data.tags.map((tag) => (
                <span>{tag}</span>
              ))}
            </div>
          </article>
        ))
      }
    </div>
  </section>
</BaseLayout>
